<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>My Pretty Baby</title>

<link rel="stylesheet" href="style.css">
</head>

<body>

<div id="desktop">

<div id="sticker1">★</div>
<div id="sticker2">:)</div>
<div id="sticker3">CD</div>

<div class="icon" onclick="openWindow('computer')">
<img src="https://cdn-icons-png.flaticon.com/512/3474/3474360.png">
<span>My Computer</span>
</div>

<div class="icon" onclick="openWindow('documents')">
<img src="https://cdn-icons-png.flaticon.com/512/716/716784.png">
<span>Documents</span>
</div>

<div class="icon" onclick="openWindow('photos')">
<img src="https://cdn-icons-png.flaticon.com/512/1375/1375106.png">
<span>Photos</span>
</div>

<div class="icon" onclick="openWindow('music')">
<img src="https://cdn-icons-png.flaticon.com/512/3659/3659784.png">
<span>Music</span>
</div>

<div class="icon" onclick="openWindow('messenger')">
<img src="https://cdn-icons-png.flaticon.com/512/9068/9068756.png">
<span>Messenger</span>
</div>

<div class="icon" onclick="openWindow('terminal')">
<img src="https://cdn-icons-png.flaticon.com/512/1792/1792899.png">
<span>Terminal</span>
</div>

</div>

<div class="window" id="computer">
<div class="titlebar">
<span>My Computer</span>
<button onclick="closeWindow('computer')">✕</button>
</div>

<div class="content">
<h3>System Information</h3>

<p>Computer Name: MY PRETTY BABY</p>
<p>Operating System: Y2K Edition</p>
<p>RAM: 1024 MB</p>
<p>Most Active Process:</p>

<pre>thinking_about_user.exe</pre>

<button onclick="openWindow('system32')">
Open system32
</button>
</div>
</div>

<div class="window" id="documents">
<div class="titlebar">
<span>Documents</span>
<button onclick="closeWindow('documents')">✕</button>
</div>

<div class="content">

<h3>Files</h3>

<div class="file" onclick="openNote('note1')">
readme.txt
</div>

<div class="file" onclick="openNote('note2')">
diagnostics.txt
</div>

<div class="file" onclick="openNote('note3')">
system_log.txt
</div>

</div>
</div>

<div class="window" id="photos">
<div class="titlebar">
<span>Photos</span>
<button onclick="closeWindow('photos')">✕</button>
</div>

<div class="content">

<h3>Photos</h3>

<img class="photo" src="assets/photo1.jpg">
<img class="photo" src="assets/photo2.jpg">
<img class="photo" src="assets/photo3.jpg">

<p>
Replace these with your own photos.
</p>

</div>
</div>

<div class="window" id="music">
<div class="titlebar">
<span>Music</span>
<button onclick="closeWindow('music')">✕</button>
</div>

<div class="content">

<h3>Playlist</h3>

<p>
Put your music website link below:
</p>

<a href="#" target="_blank">
Open Playlist
</a>

</div>
</div>

<div class="window" id="messenger">
<div class="titlebar">
<span>Messenger</span>
<button onclick="closeWindow('messenger')">✕</button>
</div>

<div class="content">

<h3>Friends Online</h3>

<div class="contact">
Trisha
<br>
Status: Online
</div>

</div>
</div>

<div class="window" id="terminal">
<div class="titlebar">
<span>Terminal</span>
<button onclick="closeWindow('terminal')">✕</button>
</div>

<div class="content">

<pre id="terminalOutput">
Type help below.
</pre>

<input
id="terminalInput"
placeholder="command..."
onkeydown="terminalCommand(event)"
>

</div>
</div>

<div class="window" id="system32">
<div class="titlebar">
<span>system32</span>
<button onclick="closeWindow('system32')">✕</button>
</div>

<div class="content">

<h3>Access Restricted</h3>

<input
type="password"
id="passwordBox"
placeholder="Password"
>

<button onclick="checkPassword()">
Unlock
</button>

<p id="passwordMessage"></p>

</div>
</div>

<div class="window" id="secret">
<div class="titlebar">
<span>final_message.txt</span>
<button onclick="closeWindow('secret')">✕</button>
</div>

<div class="content">

<h2>Hey.</h2>

<p>
If you've reached this folder,
you explored everything.

I knew you would.

Thank you for every conversation,
every joke,
every memory.

You're important to me.

♡
</p>

</div>
</div>

<div id="taskbar">

<button id="startButton">
Start
</button>

<div id="clock"></div>

</div>

<script src="script.js"></script>

</body>
</html>

@import url('https://fonts.googleapis.com/css2?family=Tahoma:wght@400;700&display=swap');

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Tahoma,sans-serif;
}

body{

height:100vh;
overflow:hidden;

background:
radial-gradient(circle at 20% 20%, rgba(255,255,255,.4) 0 60px, transparent 61px),
radial-gradient(circle at 80% 30%, rgba(255,255,255,.25) 0 90px, transparent 91px),
radial-gradient(circle at 60% 80%, rgba(255,255,255,.3) 0 70px, transparent 71px),

linear-gradient(
180deg,
#d9dde3,
#bcc3cd,
#aab1bb
);

color:#222;
}

#desktop{
padding:20px;
display:flex;
flex-direction:column;
gap:18px;
height:100vh;
}

.icon{
width:80px;
text-align:center;
cursor:pointer;
user-select:none;
}

.icon img{
width:48px;
height:48px;
display:block;
margin:auto;
filter:drop-shadow(0 2px 4px rgba(0,0,0,.2));
}

.icon span{
display:block;
margin-top:5px;
font-size:12px;
color:white;
text-shadow:1px 1px 2px rgba(0,0,0,.5);
}

.window{

display:none;

position:absolute;

top:120px;
left:180px;

width:450px;

background:#eceff4;

border:1px solid #7e8793;

border-radius:10px;

overflow:hidden;

box-shadow:
0 12px 30px rgba(0,0,0,.25);

z-index:10;
}

.titlebar{

height:34px;

background:
linear-gradient(
180deg,
#eef3fa,
#b8c5d6
);

display:flex;
justify-content:space-between;
align-items:center;

padding:0 10px;

font-weight:bold;

cursor:move;
}

.titlebar button{

width:22px;
height:22px;

border:none;

background:
linear-gradient(
180deg,
#ffffff,
#d0d5dc
);

border-radius:4px;

cursor:pointer;
}

.content{

padding:15px;

max-height:500px;

overflow:auto;
}

.content h3{
margin-bottom:12px;
}

.file{

padding:8px;

margin-bottom:6px;

border-radius:6px;

cursor:pointer;
}

.file:hover{

background:#d9e5f7;
}

.photo{

width:120px;

border-radius:8px;

margin:5px;

border:1px solid #bbb;
}

.contact{

padding:10px;

background:white;

border-radius:8px;

border:1px solid #ccc;
}

#terminalOutput{

background:black;

color:#00ff66;

padding:10px;

height:180px;

overflow:auto;

margin-bottom:10px;
}

#terminalInput{

width:100%;

padding:8px;

border:1px solid #999;
}

#taskbar{

position:fixed;

bottom:0;
left:0;

width:100%;

height:40px;

background:
linear-gradient(
180deg,
#d6dce5,
#9aa5b5
);

display:flex;

align-items:center;

justify-content:space-between;

padding:0 12px;

border-top:1px solid #7f8791;
}

#startButton{

padding:5px 16px;

border:none;

background:
linear-gradient(
180deg,
#f4f6f8,
#c8d0db
);

border-radius:7px;

font-weight:bold;

cursor:pointer;
}

#clock{

font-size:13px;
font-weight:bold;
}

#sticker1,
#sticker2,
#sticker3{

position:absolute;

font-weight:bold;

color:rgba(255,255,255,.75);

user-select:none;
pointer-events:none;
}

#sticker1{
top:60px;
right:120px;
font-size:24px;
}

#sticker2{
bottom:100px;
right:220px;
font-size:20px;
}

#sticker3{
top:220px;
right:80px;
font-size:18px;
}

button{

padding:8px 12px;

cursor:pointer;

border-radius:6px;

border:1px solid #aaa;

background:
linear-gradient(
180deg,
#ffffff,
#d8dce1
);
}

input{

padding:8px;

border:1px solid #999;

border-radius:5px;
}
